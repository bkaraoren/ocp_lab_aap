# =============================================================================
# Secrets file — copy to secrets.yml and fill in values
# Encrypt with: ansible-vault encrypt vars/secrets.yml
#
# NEVER commit secrets.yml to git — only this .example file.
# All secrets should also be stored in HashiCorp Vault for runtime use.
# =============================================================================

# ─── HashiCorp Vault ───
vault_root_token: "hvs.xxxxx"
vault_unseal_key: "base64-encoded-unseal-key"
vault_aap_integration_token: "hvs.xxxxx"

# ─── Google OAuth (used by OCP, AAP, Vault, Grafana OIDC) ───
google_client_secret: "GOCSPX-your-google-client-secret"

# ─── GitHub OAuth (used by OCP login) ───
github_client_secret: "your-github-oauth-client-secret"

# ─── Grafana OAuth (separate Google OAuth app for Grafana OIDC) ───
grafana_oauth_client_id: "your-grafana-google-client-id.apps.googleusercontent.com"
grafana_oauth_client_secret: "GOCSPX-your-grafana-google-secret"

# ─── Slack ───
slack_webhook_url: "your-slack-incoming-webhook-url"

# ─── Let's Encrypt / name.com DNS ───
namecom_username: "your-namecom-username"
namecom_api_token: "your-namecom-api-token"

# ─── Vault Paths Reference ───
# The following secrets are managed in Vault and used at runtime by AAP,
# ESO (External Secrets Operator), and Grafana. They do NOT need to be
# in this file — they are auto-populated by the store-secrets playbook
# or created during initial setup.
#
#   secret/ocp/google-oauth        → client_id, client_secret
#   secret/ocp/slack               → webhook_url, channel
#   secret/ocp/aap-gateway-oauth   → client_secret
#   secret/ocp/cert-renewal-sa     → bearer_token, host
#   secret/ocp/grafana             → admin_user, admin_password
#   secret/ocp/grafana-oauth       → client_id, client_secret
#   secret/ocp/eda-alertmanager-webhook → username, password
#   secret/aap/admin               → username, password
#   secret/aap/portal              → oauth_client_id, oauth_client_secret, aap_token
#   secret/aap/scm                 → github_token
#   secret/vault/tokens            → root_token, unseal_key
#   secret/vault/root              → root_token
#   secret/dns/namecom             → username, api_token
#   secret/letsencrypt/certs       → tls.crt (base64), tls.key (base64), ca.crt (base64)
#   secret/registry/pull-secret    → .dockerconfigjson
